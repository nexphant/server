{
    "name": "nexphant/server",
    "description": "HTTP server for nexphant framework",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Nexphant\\Server\\": "src/",
            "Nexphant\\": "src/Foundation/"
        },
        "files": ["src/helpers.php", "src/Foundation/PathHelpers.php"]
    },
    "require": {
        "php": ">=8.1",
        "ext-pcntl": "*",
        "ext-posix": "*",
        "nexphant/core": "^0.0",
        "nexphant/runtime": "^0.0",
        "nexphant/support": "^0.0"
    },
    "suggest": {
        "ext-zlib": "For compression middleware",
        "ext-redis": "For Redis session storage",
        "nexphant/database": "For database integration"
    }
}

