{
    "name": "nexph/server",
    "description": "HTTP server for Nexph framework",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Nexph\\Server\\": "src/",
            "Nexph\\": "src/Foundation/"
        },
        "files": ["src/helpers.php"]
    },
    "require": {
        "php": ">=8.1",
        "ext-pcntl": "*",
        "ext-posix": "*",
        "nexph/core": "^0.1",
        "nexph/runtime": "^0.1",
        "nexph/support": "^0.1"
    },
    "suggest": {
        "ext-zlib": "For compression middleware",
        "ext-redis": "For Redis session storage",
        "nexph/database": "For database integration"
    }
}

